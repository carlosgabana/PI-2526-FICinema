# FICinema - variables para Render
# No se suben claves reales. Configúralas en el panel de Render.

DEBUG=False
SECRET_KEY=generar_en_render

DATABASE_URL=usar_la_connection_string_de_render
DB_SSL_REQUIRE=True
PAYMENT_SIMULATION_MODE=True

ALLOWED_HOSTS=.onrender.com,ficinema.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,https://ficinema.onrender.com
PUBLIC_BASE_URL=https://ficinema.onrender.com

TMDB_API_KEY=pon_aqui_tu_api_key
TMDB_ACCESS_TOKEN=pon_aqui_tu_access_token
OMDB_API_KEY=pon_aqui_tu_api_key_omdb
YOUTUBE_API_KEY=opcional_api_key_youtube_para_trailers
GOOGLE_MAPS_API_KEY=opcional_api_key_google_maps

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Render/demo con Resend sin dominio propio: se centraliza el correo de prueba.
EMAIL_PROVIDER=resend
EMAIL_REQUIRED_FOR_PURCHASE=False
EMAIL_TIMEOUT=10
EMAIL_TEST_RECIPIENT_OVERRIDE=ficinema.notificaciones@gmail.com
RESEND_API_KEY=poner_en_render
RESEND_FROM_EMAIL=FICinema <onboarding@resend.dev>
DEFAULT_FROM_EMAIL=FICinema <onboarding@resend.dev>
