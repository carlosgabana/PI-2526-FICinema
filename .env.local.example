# FICinema - configuración recomendada para ejecutar con Python local
# Copia este archivo como .env y rellena las claves reales. No subas .env a Git.

SECRET_KEY=django-insecure-dev-key-local
DEBUG=True

TMDB_API_KEY=pon_aqui_tu_api_key
TMDB_ACCESS_TOKEN=pon_aqui_tu_access_token
OMDB_API_KEY=pon_aqui_tu_api_key_omdb
YOUTUBE_API_KEY=opcional_api_key_youtube_para_trailers
GOOGLE_MAPS_API_KEY=opcional_api_key_google_maps

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
PAYMENT_SIMULATION_MODE=True

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.trycloudflare.com,.ngrok-free.app
CSRF_TRUSTED_ORIGINS=https://*.trycloudflare.com,https://*.ngrok-free.app
PUBLIC_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=
DB_SSL_REQUIRE=False
SQLITE_PATH=

# Local con Gmail SMTP: envía al correo real del usuario registrado.
EMAIL_PROVIDER=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=ficinema.notificaciones@gmail.com
EMAIL_HOST_PASSWORD=contraseña_de_aplicacion_de_gmail
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=FICinema <ficinema.notificaciones@gmail.com>
EMAIL_TIMEOUT=10
EMAIL_REQUIRED_FOR_PURCHASE=False

# No usar en local si se quiere probar envío real al email de cada usuario.
EMAIL_TEST_RECIPIENT_OVERRIDE=

# Solo para producción/demo con Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=FICinema <onboarding@resend.dev>
