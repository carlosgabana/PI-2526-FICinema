SECRET_KEY=django-insecure-dev-key
DEBUG=True

TMDB_API_KEY=pon_aqui_tu_api_key
TMDB_ACCESS_TOKEN=pon_aqui_tu_access_token
OMDB_API_KEY=pon_aqui_tu_api_key_omdb
OMDB_ACCESS_TOKEN=pon_aqui_tu_access_token_omdb
YOUTUBE_API_KEY=opcional_api_key_youtube_para_trailers
GOOGLE_MAPS_API_KEY=opcional_api_key_google_maps

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
PAYMENT_SIMULATION_MODE=True

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=
# Local mismo equipo: http://localhost:8000
# Local/Docker desde móvil: usar la IP del ordenador, por ejemplo http://192.168.1.50:8000
# Render: https://ficinema.onrender.com
PUBLIC_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=
DB_SSL_REQUIRE=False
SQLITE_PATH=

# Email
# Desarrollo local: muestra el correo en consola y no envía mensajes reales.
EMAIL_PROVIDER=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_REQUIRED_FOR_PURCHASE=False
EMAIL_TIMEOUT=10
# En demo con Resend sin dominio se puede centralizar el envío real aquí.
EMAIL_TEST_RECIPIENT_OVERRIDE=
DEFAULT_FROM_EMAIL=FICinema <no-reply@ficinema.local>

# Producción con Resend.
# Sin dominio propio verificado, Resend solo permite pruebas con onboarding@resend.dev
# y envío al correo asociado a la cuenta de Resend. En esta entrega se puede
# usar EMAIL_TEST_RECIPIENT_OVERRIDE=ficinema.notificaciones@gmail.com para
# centralizar los correos de prueba sin bloquear la compra de entradas.
# Para enviar a cualquier usuario registrado hay que verificar un dominio propio
# y usar un remitente de ese dominio, por ejemplo: FICinema <entradas@tudominio.com>.
RESEND_API_KEY=
RESEND_FROM_EMAIL=FICinema <onboarding@resend.dev>

# Alternativa SMTP clásica.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
